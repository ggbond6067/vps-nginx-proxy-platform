# 反代网关容器名称（管理面板会基于该名称执行 reload）
NGINX_CONTAINER_NAME=nginx-gateway
# 证书代理容器名称（管理面板会在该容器内执行 acme.sh）
CERT_AGENT_CONTAINER_NAME=cert-agent

# 管理面板端口（默认只绑定到 127.0.0.1，建议通过 SSH 隧道访问）
PANEL_PORT=18080

# 管理面板镜像（建议使用 Docker Hub 仓库；用于 docker compose pull 更新）
PANEL_IMAGE=docker.io/your-dockerhub-username/vps-nginx-proxy-platform-proxy-panel:latest

# 管理面板基础认证（建议设置；留空则不启用认证）
PANEL_USER=admin
PANEL_PASSWORD=change_me

# VPS 公网 IP（兼容旧配置；新版本优先使用下方 IPv4 / IPv6 字段）
VPS_PUBLIC_IP=1.2.3.4

# VPS 公网 IPv4 / IPv6（用于 Cloudflare DNS 自动绑定）
VPS_PUBLIC_IPV4=
VPS_PUBLIC_IPV6=

# 反代网络名称（用于服务发现和部署模板）
PROXY_NETWORK_NAME=proxy_net

# Cloudflare API Token（至少需要 Zone.DNS:Edit 权限）
CF_API_TOKEN=

# Cloudflare Zone ID（主域对应的 Zone）
CF_ZONE_ID=

# Cloudflare DNS 记录是否走代理（true/false）
CF_PROXIED=true

# Cloudflare DNS TTL（1 表示自动）
CF_TTL=1
